# =============================================================================
# Snowflake Credentials (nur für VM/lokal, nicht in Git!)
# =============================================================================
# In Snowflake Container Runtime wird keine .env Datei gebraucht.
#
# Setup:
#   1. Diese Datei kopieren: cp .env.example .env
#   2. Account und User eintragen
#   3. Auth-Methode wählen (siehe unten)
#   4. Speichern (Ctrl+S)
# =============================================================================

SF_ACCOUNT=dein_account.eu-central-1
SF_USER=dein_username
SF_ROLE=ROLE_DS
SF_WAREHOUSE=ML_WH
SF_DATABASE=ML_DB
SF_SCHEMA=DATA

# =============================================================================
# Auth-Methode: EINE Zeile einkommentieren
# =============================================================================

# Key-Pair (empfohlen, einmalig einrichten, kein MFA-Prompt)
# Anleitung: openssl genrsa 2048 | openssl pkcs8 -topk8 -nocrypt -out ~/.snowflake/rsa_key.p8
#            openssl rsa -in ~/.snowflake/rsa_key.p8 -pubout -out ~/.snowflake/rsa_key.pub
#            Dann Public Key in Snowflake hinterlegen:
#            ALTER USER dein_user SET RSA_PUBLIC_KEY='...';
# SF_PRIVATE_KEY_PATH=~/.snowflake/rsa_key.p8

# External Browser (nur wenn SSO/SAML auf dem Account konfiguriert ist)
# SF_AUTHENTICATOR=externalbrowser

# Passwort (Fallback, kann MFA-Prompt auslösen)
# SF_PASSWORD=dein_passwort
