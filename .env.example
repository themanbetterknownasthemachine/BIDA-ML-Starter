# =============================================================================
# BIDA ML Starter — Environment Variables
# =============================================================================
# Kopiere diese Datei zu .env und trage deine Werte ein.
# NUR für VM/lokale Entwicklung nötig — in Snowflake Notebooks nicht benötigt.
# .env wird NICHT in Git committet!
# =============================================================================

# Snowflake Connection
SF_ACCOUNT=pistor.eu-central-1
SF_USER=dein_username
SF_PASSWORD=
SF_PRIVATE_KEY_PATH=~/.ssh/snowflake_key.p8
SF_ROLE=ROLE_DS
SF_WAREHOUSE=ML_WH
SF_DATABASE=ML_DB
SF_SCHEMA=DATA
